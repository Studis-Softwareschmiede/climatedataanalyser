# MariaDB-Credentials für den db-Service (compose.fragment.yml).
# Diese Datei ist die VORLAGE — KEIN Plaintext-Secret committen.
# Lebenszyklus (analog Brewing .env.gpg-Pattern):
#   1. cp .env.db.example .env.db
#   2. .env.db lokal mit echten Passwörtern befüllen
#   3. .env.db ist gitignored, NIE committen
#   4. Production: per Secrets-Tool (sops, .env.gpg, K8s-Secret) injizieren
#
# Hinweise:
#  - MARIADB_ROOT_PASSWORD ist nur intern (root@localhost im Container);
#    der App-Zugriff läuft IMMER über MARIADB_USER.
#  - DB- und User-Namen sollten je Projekt gesetzt sein, nicht "app" lassen.

MARIADB_DATABASE=app
MARIADB_USER=app
MARIADB_PASSWORD=changeme-via-env-gpg
MARIADB_ROOT_PASSWORD=changeme-via-env-gpg
